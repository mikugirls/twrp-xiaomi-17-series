on init
    start vendor.boot-qti

on early-fs
    write /proc/sys/walt/sched_lib_name "recovery,magiskboot,Updater,updater,update_engine_sideload"
    write /proc/sys/walt/sched_lib_mask_force 255

on fs
    wait /dev/block/platform/soc/${ro.boot.bootdevice}
    symlink /dev/block/platform/soc/${ro.boot.bootdevice} /dev/block/bootdevice
    write /proc/sys/kernel/firmware_config/force_sysfs_fallback 1
    chmod 0660 /dev/qseecom
    chown system drmrpc /dev/qseecom
    chmod 0664 /dev/ion
    chown system system /dev/ion
    mkdir /mnt/vendor 0775 shell system
    mkdir /mnt/vendor/persist 0775 shell system
    wait /dev/block/bootdevice/by-name/persist
    mount ext4 /dev/block/bootdevice/by-name/persist /persist noatime nosuid nodev barrier=1
    mount none /persist /mnt/vendor/persist bind
    install_keyring

on post-fs
    start odm.variant-script

on boot
    setprop sys.usb.config adb

on property:twrp.modules.loaded=true
    # Mount firmware
    mkdir /vendor/firmware
    mkdir /vendor/firmware_mnt
    mkdir /vendor/firmware_mnt/image
    mount vfat /dev/block/bootdevice/by-name/modem${ro.boot.slot_suffix} /vendor/firmware_mnt ro
    mount none /vendor/firmware_mnt/image /vendor/firmware bind rec
    # Load ADSP firmware for PMIC
    wait /sys/kernel/boot_adsp/boot
    write /sys/kernel/boot_adsp/boot 1
    # This make USB-OTG work
    wait /sys/kernel/boot_adsp/ssr
    write /sys/kernel/boot_adsp/ssr 1
    wait /sys/class/power_supply/battery
    start vendor.health-default

on property:servicemanager.ready=true
    setprop sys.boot_completed 1

on property:twrp.variant.files_copied=1
    start odm.vibratorfeature-hal-service
    start odm.touch_report

on property:twrp.variant.files_copied=1 && property:twrp.variant.detected=nezha
    stop odm.touch_report

on property:twrp.variant.files_copied=1 && property:ro.keymint=nxp && property:twrp.variant.detected=pandora
    start odm.pandora-nxp-stabilize

on property:twrp.variant.files_copied=1 && property:ro.keymint=nxp && property:twrp.variant.detected=popsicle
    start odm.popsicle-nxp-gate

on property:twrp.variant.files_copied=1 && property:ro.keymint=thales
    start odm.weaver_hal_service

on property:twrp.variant.files_copied=1 && property:ro.keymint=thales && property:twrp.variant.detected=nezha
    start odm.secure_element_hal_service

on property:twrp.variant.files_copied=1 && property:ro.keymint=thales && property:twrp.variant.detected=nezha
    start odm.nezha-goodix-stop-gate

# combined_v26: pandora-only NXP stabilization gate.
service odm.pandora-nxp-stabilize /system/bin/pandora-nxp-stabilize.sh
    disabled
    oneshot
    user root
    group root shell
    seclabel u:r:recovery:s0

# combined_v26: popsicle-only NXP startup gate.
service odm.popsicle-nxp-gate /system/bin/popsicle-nxp-gate.sh
    disabled
    oneshot
    user root
    group root shell
    seclabel u:r:recovery:s0

# combined_v26: nezha-only Goodix secure-element stop gate.
service odm.nezha-goodix-stop-gate /system/bin/nezha-goodix-stop-gate.sh
    disabled
    oneshot
    user root
    group root shell
    seclabel u:r:recovery:s0
